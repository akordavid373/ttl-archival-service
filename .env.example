# Application Environment
ENVIRONMENT=development
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=1
CONFIG_VERSION=1.0.0

# Database Configuration
DATABASE_URL=sqlite:///./ttl_archival.db
# For PostgreSQL: postgresql://user:password@localhost/ttl_archival
# For MySQL: mysql://user:password@localhost/ttl_archival
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false

# Redis Configuration (for caching, optional)
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_RETRY_ON_TIMEOUT=true

# Archive Storage
ARCHIVE_STORAGE_PATH=./archives
MAX_FILE_SIZE_MB=1024
COMPRESSION_ENABLED=true
ENCRYPTION_ENABLED=false
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30

# Security
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Feature Flags
ENABLE_SEARCH=true
ENABLE_ANALYTICS=true
ENABLE_AUDIT_LOG=true
ENABLE_SCHEDULER=true
ENABLE_NOTIFICATIONS=false
ENABLE_API_RATE_LIMITING=true
ENABLE_ADVANCED_FILTERS=true

# Rate Limiting
RATE_LIMIT_RPM=60
RATE_LIMIT_RPH=1000
RATE_LIMIT_RPD=10000
RATE_LIMIT_BURST=10

# External Services
NOTIFICATION_SERVICE_URL=
NOTIFICATION_SERVICE_KEY=
ANALYTICS_SERVICE_URL=
ANALYTICS_SERVICE_KEY=
BACKUP_SERVICE_URL=
BACKUP_SERVICE_KEY=

# Scheduler Configuration
CLEANUP_INTERVAL_HOURS=1
BACKUP_INTERVAL_HOURS=24
HEALTH_CHECK_INTERVAL_MINUTES=5
MAX_WORKER_THREADS=4

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=
LOG_MAX_FILE_SIZE_MB=10
LOG_BACKUP_COUNT=5
ENABLE_JSON_LOGS=false

# Secret Management
SECRET_STORAGE_PATH=./secrets
SECRET_MASTER_KEY=your-master-key-here-change-this-in-production
