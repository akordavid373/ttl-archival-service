# Staging environment sample
APP_ENV=staging
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=2
DATABASE_URL=postgresql://user:password@staging-db/ttl_archival
REDIS_URL=redis://staging-redis:6379/0
STELLAR_NETWORK=futurenet
CONTRACT_ID=
